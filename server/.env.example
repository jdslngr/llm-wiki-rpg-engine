# Copy this file to ".env" (same folder) and fill in your real key.
# The real .env is git-ignored and never committed.

# --- AI provider (Build Plan §1.5) ---------------------------------------
# Phase 0 uses OpenRouter: one key reaches Claude, GPT, Gemini, and more.
LLM_PROVIDER=openrouter

# Your OpenRouter API key, from https://openrouter.ai/keys (starts with "sk-or-...")
LLM_API_KEY=sk-or-your-key-here

# Which model to use. Browse options at https://openrouter.ai/models
# The game's default brain is Anthropic's Sonnet:
LLM_MODEL=anthropic/claude-sonnet-4.6

# --- Server ---------------------------------------------------------------
PORT=3001

# --- Admin / authoring tool ------------------------------------------------
# Comma-separated usernames allowed to use the chapter authoring tool (admin-gated).
# These users see "Author a chapter" and can call /api/admin/*. Leave empty to disable.
# Authored chapters are stored in the database — set DATABASE_URL below so they PERSIST
# across restarts (with the in-memory store they're lost on restart).
# ADMIN_USERNAMES=yourname

# A long random string used to encrypt BYO API keys at rest (Phase 5).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Back this up safely — if lost, users must re-enter their keys.
# APP_SECRET=your-random-secret-here

# --- Database (Phase 2) ----------------------------------------------------
# Where playthroughs are persisted. If set & reachable, the game uses Postgres and
# state survives restarts/refresh. If UNSET, the server falls back to an in-memory
# store (zero-setup `npm run dev`, but state resets when the server restarts).
# `docker compose up` sets this automatically. To get persistence in plain dev, run
# just the db container (`docker compose up -d db`) and uncomment the line below:
# DATABASE_URL=postgres://archipelago:archipelago@localhost:5432/archipelago

# Optional: log per-turn token usage (incl. cache hits) to the server console.
# Handy while tuning cost; leave unset/false otherwise.
# LOG_TOKEN_USAGE=true

# --- Cookies ----------------------------------------------------------------
# Set to 'true' ONLY when ALL access to this server is via HTTPS (reverse proxy,
# Cloudflare Tunnel, etc.). Default off for plain-HTTP LAN dev. NOTE: if the same
# server is reached BOTH via HTTPS and plain-HTTP LAN, turning this on breaks the
# LAN path (browsers won't send Secure cookies over http).
# COOKIE_SECURE=true
